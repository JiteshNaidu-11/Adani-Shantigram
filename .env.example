# All enquiry forms use FormSubmit → info@propraiserealtors.com (see src/constants/formSubmit.ts).
# After submit, users are redirected to {origin}/thank-you
#
# Optional: override contact email for footer/legal (defaults to info@propraiserealtors.com)
# VITE_COMPANY_EMAIL=
#
# Optional: override display phone (defaults to +91 96015 93111 → tel:+919601593111)
# VITE_COMPANY_PHONE=
